{
  "name": "horizon-engine",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "pnpm --filter @engine/benchmark dev",
    "dev:large": "pnpm --filter @engine/large-scene dev",
    "dev:pbr": "pnpm --filter @engine/pbr-demo dev",
    "dev:anim": "pnpm --filter @engine/animation-demo dev",
    "dev:editor": "pnpm --filter @engine/editor-demo dev",
    "build": "tsc --build",
    "clean": "rm -rf packages/*/dist examples/*/dist"
  },
  "devDependencies": {
    "@types/three": "^0.183.1",
    "@webgpu/types": "^0.1.61",
    "typescript": "^5.7.3",
    "vite": "^6.2.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
